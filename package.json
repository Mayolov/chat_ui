{
  "name": "local-chat-ui",
  "version": "1.0.0",
  "description": "A local ChatGPT/Claude-style chat interface that works with any OpenAI-compatible API. Supports streaming, artifacts, file uploads, and conversation history.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,green \"node server.js\" \"vite\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "prod": "vite build && NODE_ENV=production node server.js",
    "server": "node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "lucide-react": "^0.344.0",
    "highlight.js": "^11.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  }
}
